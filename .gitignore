# ============================================================
# .gitignore — Kaniya Kodes React + Vite portfolio
# ============================================================

# Dependencies — never commit node_modules
node_modules/
.pnp
.pnp.js

# Build output — regenerated by `npm run build`
dist/
dist-ssr/

# Environment variables — keep secrets out of git
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor/OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code settings (optional — remove if you want to share settings with team)
.vscode/*
!.vscode/extensions.json

# Local test artifacts
*.local

# Vite cache
.vite/
